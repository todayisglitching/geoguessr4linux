{
  "name": "geoguessr-steam-edition",
  "version": "1.0.0",
  "main": "main.js",
  "license": "MIT",
  "scripts": {
    "start": "electron . --env=prod",
    "start:dev": "electron . --env=dev",
    "start:linux-x11": "GEOGUESSR_PERF=1 GEOGUESSR_IN_PROCESS_GPU=1 GEOGUESSR_NO_FULLSCREEN=1 XDG_SESSION_TYPE=x11 GDK_BACKEND=x11 QT_QPA_PLATFORM=xcb electron . --env=prod",
    "start:linux-safe": "GEOGUESSR_PERF=1 GEOGUESSR_DISABLE_HW_ACCEL=1 GEOGUESSR_NO_FULLSCREEN=1 electron . --env=prod",
    "build:linux": "electron-builder --linux AppImage"
  },
  "dependencies": {
    "electron-log": "^5.2.0",
    "steamworks-ffi-node": "^0.10.0",
    "url": "^0.11.4"
  },
  "devDependencies": {
    "electron": "32.2.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.geoguessr.duels",
    "productName": "GeoGuessr Duels",
    "files": [
      "**/*"
    ],
    "extraResources": [
      {
        "from": "steamworks_sdk/redistributable_bin",
        "to": "steamworks_sdk/redistributable_bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true,
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Game"
    }
  }
}
